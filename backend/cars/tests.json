{
  "tests": [
    {
      "name": "CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "List without token returns 401",
      "method": "GET",
      "path": "/",
      "expectedStatus": 401
    },
    {
      "name": "Create without token returns 401",
      "method": "POST",
      "path": "/",
      "body": {"make": "BMW", "model": "X5"},
      "expectedStatus": 401
    }
  ]
}
